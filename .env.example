# Google Ads Agent — example environment
#
# Copy to `.env` and fill in only the values you need. The extension has TWO
# independent auth lanes. You can enable either, both, or switch between them
# at any time.
#
# ─────────────────────────────────────────────────────────────────────────────
# METHOD 1 — Local Google Ads API (static, power-user)
# Uses your own Google Cloud project. Best when you want programmatic access
# to a specific set of accounts under a fixed MCC (manager) account.
# ─────────────────────────────────────────────────────────────────────────────

# Required: developer token from ads.google.com → Tools & Settings → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=

# Required: OAuth2 client from Google Cloud Console → APIs & Services → Credentials
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Required: refresh token for the Google account that owns the MCC
# (generate with https://developers.google.com/oauthplayground or google-ads-python)
GOOGLE_ADS_REFRESH_TOKEN=

# Optional: MCC (manager) account id, digits only, e.g. 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# METHOD 2 — Remote proxy (one-click login via googleadsagent.ai)
# Sign in with ANY Google account that has Google Ads access. No Cloud Console
# setup. Just run `/google-ads:login` and approve on Google's consent screen.
# ─────────────────────────────────────────────────────────────────────────────

# Required for Method 2: base URL of the proxy deployment.
GADS_SITE_URL=https://googleadsagent.ai

# Optional legacy: paste a session id from browser localStorage.
# v2.4+ prefers `/google-ads:login` — you won't need to set this manually.
# GADS_SITE_SESSION_ID=
