{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_gaql",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));const q=(d.tool_input?.query||'').trim();if(!q.toUpperCase().startsWith('SELECT')){process.stderr.write('Only SELECT queries allowed.');process.exit(2);}console.log(JSON.stringify({decision:'allow'}))\"",
            "name": "validate-gaql",
            "description": "Validates GAQL queries to prevent write operations"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${extensionPath}/hooks/log-tool-call.js",
            "name": "audit-log",
            "description": "Logs all Google Ads tool calls for audit trail"
          }
        ]
      }
    ]
  }
}
